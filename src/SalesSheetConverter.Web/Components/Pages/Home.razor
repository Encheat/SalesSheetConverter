@page "/"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using SalesSheetConverter.Web.Services
@using SalesSheetConverter.Web.Constants

@inherits LayoutComponentBase

@inject FileTransferService FileTransferService
@inject NavigationManager Navigation

<h3>Sales Sheet Converter</h3>

<p>Upload the images of your sales sheets:</p>

<InputFile OnChange="OnFileSelected" multiple accept=@string.Join(",", FileTypeConstants.AllowedFileTypes) />

<br /><br />

<button @onclick="Upload" disabled="@(_files.Count == 0)">
    Convert to CSV
</button>

@if (!string.IsNullOrWhiteSpace(_result))
{
    <h4>Result</h4>
    <pre>@_result</pre>
}

@code {
    private List<UploadedFile> _files = new();
    private string? _result;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var selectedFiles = new List<UploadedFile>();

        foreach (var file in e.GetMultipleFiles())
        {
            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            selectedFiles.Add(new UploadedFile
            {
                Name = file.Name,
                ContentType = file.ContentType,
                Bytes = memoryStream.ToArray()
            });
        }

        _files = selectedFiles;
        FileTransferService.Files = _files;
        _result = null;
    }

    private async Task Upload()
    {
        if (_files.Count == 0){
            _result = "You must upload at least one file!";
            return;
        }

        FileTransferService.Files = _files;

        Navigation.NavigateTo("/download");
    }
}