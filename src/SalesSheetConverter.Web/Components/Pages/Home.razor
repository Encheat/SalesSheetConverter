@page "/"
@rendermode InteractiveServer

@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@using SalesSheetConverter.Web.Services
@using SalesSheetConverter.Web.Constants
@using SalesSheetConverter.Web.Spinner

@inherits LayoutComponentBase

@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory
@inject IUploadService UploadService
@inject ISpinnerProvider SpinnerProvider

<h3>Sales Sheet Converter</h3>

<p>Upload the images of your sales sheets:</p>

<InputFile OnChange="OnFileSelected" multiple accept=@string.Join(",", FileTypeConstants.AllowedFileTypes) />

<br /><br />

<button @onclick="Upload" disabled="@(_files.Count == 0)">
    Convert to CSV
</button>

@if (SpinnerProvider.IsBusy){
    <div id="page-loader">
        <div class="spinner"></div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(_result))
{
    <h4>Result</h4>
    <pre>@_result</pre>
}

@code {
    private List<IBrowserFile> _files = new();
    private string? _result;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _files = e.GetMultipleFiles().ToList();
        _result = null;
    }

    private async Task Upload()
    {
        if (_files.Count == 0){
            _result = "You must upload at least one file!";
            return;
        }
        SpinnerProvider.Wait();

        try
        {
            _result = await UploadService.Upload(_files);
        }
        finally
        {
            SpinnerProvider.Resume();
        }
    }

    protected override void OnInitialized()
    {
        SpinnerProvider.OnSpinnerStateChanged += HandleSpinnerChanged;
    }

    private void HandleSpinnerChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SpinnerProvider.OnSpinnerStateChanged -= HandleSpinnerChanged;
    }
}