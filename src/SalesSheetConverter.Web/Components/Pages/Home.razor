@page "/"
@rendermode InteractiveServer

@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms

@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory
<h3>Sales Sheet Converter</h3>

<p>Upload the images of your sales sheets:</p>

<InputFile OnChange="OnFileSelected" multiple accept=@string.Join(",", allowedTypes) />

<br /><br />

<button @onclick="Upload" disabled="@(_files.Count == 0)">
    Convert to CSV
</button>

@if (!string.IsNullOrWhiteSpace(_result))
{
    <h4>Result</h4>
    <pre>@_result</pre>
}

@code {
    private List<IBrowserFile> _files = new();
    private string? _result;
    string[] allowedTypes = new[]
    {
        "image/jpeg",
        "image/jpg",
        "image/png",
        "image/gif",
        "image/bmp",
        "image/webp",
        "image/tiff",
        "image/svg+xml"
    };

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _files = e.GetMultipleFiles().ToList();
        _result = null;
    }

    private async Task Upload()
    {
        if (_files.Count == 0) return;

        try{
            using var content = new MultipartFormDataContent();

            foreach (var file in _files)
            {
                if (!allowedTypes.Contains(file.ContentType, StringComparer.OrdinalIgnoreCase))
                {
                    _result = $"Only image files are allowed: {file.Name} is invalid type {file.ContentType}.";
                    return;
                }
                
                using var stream = file.OpenReadStream(10 * 1024 * 1024);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                
                var fileContent = new ByteArrayContent(ms.ToArray());
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
                content.Add(fileContent, "files", file.Name);
            }

            var http = HttpClientFactory.CreateClient("FunctionsApi");

            var response = await http.PostAsync("http://localhost:7071/api/ConvertToCsv", content);

            if (!response.IsSuccessStatusCode)
            {
                _result = await response.Content.ReadAsStringAsync();
                return;
            }

            var contentDisposition = response.Content.Headers.ContentDisposition;
            var fileName = contentDisposition?.FileNameStar?.Trim('"')
                ?? contentDisposition?.FileName?.Trim('"')
                ?? "Sales.csv";

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv", base64);
        }
        catch (Exception ex)
        {
            _result = $"Upload failed: {ex.Message}";
        }
    }
}