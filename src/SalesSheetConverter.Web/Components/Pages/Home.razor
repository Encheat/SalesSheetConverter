@page "/"
@rendermode InteractiveServer

@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms

@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory
<h3>Sales Sheet Converter</h3>

<p>Upload the images of your sales sheets:</p>

<InputFile OnChange="OnFileSelected" multiple />

<br /><br />

<button @onclick="Upload" disabled="@(_files.Count == 0)">
    Convert to CSV
</button>

@if (!string.IsNullOrWhiteSpace(_result))
{
    <h4>Result</h4>
    <pre>@_result</pre>
}

@code {
    private List<IBrowserFile> _files = new();
    private string? _result;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _files = e.GetMultipleFiles().ToList();
        _result = null;
    }

        private async Task Upload()
    {
        if (_files.Count == 0) return;

        using var content = new MultipartFormDataContent();

        foreach (var file in _files)
        {
            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);

            content.Add(fileContent, "files", file.Name);
        }

        using var http = HttpClientFactory.CreateClient("FunctionsApi");

        var response = await http.PostAsync(
            "http://localhost:7071/api/ConvertToCsv",
            content);

        if (!response.IsSuccessStatusCode)
        {
            _result = await response.Content.ReadAsStringAsync();
            return;
        }

        var bytes = await response.Content.ReadAsByteArrayAsync();
        var base64 = Convert.ToBase64String(bytes);

        await JS.InvokeVoidAsync(
            "downloadFile",
            "Sales.csv",
            "text/csv",
            base64);
        _result = "CSV downloaded successfully.";
    }
}